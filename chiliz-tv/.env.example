# ==============================================================================
# ChilizTV Smart Contracts - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control!
#
# Usage with deploy.sh:
#   cp .env.example .env
#   # Fill in values below
#   ./deploy.sh --network chilizTestnet --all
#
# Usage with forge directly:
#   source .env
#   forge script script/DeployAll.s.sol --rpc-url $RPC_URL --broadcast -vvvv

# ==============================================================================
# REQUIRED — Network
# ==============================================================================
# Fill in values for the network you are deploying to.
# To switch networks, update these values (or keep .env.chilizTestnet / .env.chilizMainnet and symlink).

# RPC endpoint
#   Chiliz Spicy Testnet: https://spicy-rpc.chiliz.com
#   Chiliz Mainnet:       https://rpc.chiliz.com
RPC_URL=https://spicy-rpc.chiliz.com

# EVM chain id
#   Chiliz Spicy Testnet: 88882
#   Chiliz Mainnet:       88888
CHAIN_ID=88882

# Block explorer (informational — printed after deploy)
#   Spicy:   https://testnet.chiliscan.com
#   Mainnet: https://chiliscan.com
EXPLORER_URL=https://testnet.chiliscan.com

# Etherscan-compatible verifier API (for forge verify-contract)
#   Spicy:   https://api.routescan.io/v2/network/testnet/evm/88882/etherscan/api
#   Mainnet: https://api.routescan.io/v2/network/mainnet/evm/88888/etherscan/api
VERIFIER_URL=https://api.routescan.io/v2/network/testnet/evm/88882/etherscan/api

# Extra flags passed to `forge script`
#   Chiliz needs --legacy (no EIP-1559) and a high legacy gas price.
#   --skip-simulation avoids Chiliz-specific simulation failures.
#   Spicy:   --legacy --with-gas-price 3500000000001 --skip-simulation
#   Mainnet: --legacy --with-gas-price 100000000000
FORGE_FLAGS=--legacy --with-gas-price 3500000000001 --skip-simulation

# ==============================================================================
# REQUIRED — Deployment
# ==============================================================================

# Deployer private key (hot wallet — NOT your multisig key)
# ⚠️  Use a dedicated deployment wallet. See SECURITY section below.
PRIVATE_KEY=

# Gnosis Safe multisig address (treasury + final owner of all contracts)
# Held as `treasury` on the LiquidityPool (sole controller of treasury rotation
# and accrued-treasury withdrawals). Also the platform-fee sink for streaming
# and the swap router.
SAFE_ADDRESS=

# Pool admin key — DEFAULT_ADMIN_ROLE + PAUSER_ROLE on the LiquidityPool.
# MUST be different from SAFE_ADDRESS. The pool enforces a hard split:
#   - SAFE_ADDRESS  rotates the treasury and pulls accruedTreasury.
#   - ADMIN_ADDRESS authorizes matches, sets caps/fees, pauses, upgrades.
# Reusing the same address for both would let an admin compromise drain the
# treasury. Required for: --all, --pool
ADMIN_ADDRESS=

# ==============================================================================
# REQUIRED — Token & DEX Addresses
# ==============================================================================

# USDC token address (6 decimals)
# Required for: --all, --swap, --stream, --pool
USDC_ADDRESS=

# Kayen DEX MasterRouterV2 address
# Required for: --all, --swap, --stream
# Docs: https://docs.kayen.org
KAYEN_ROUTER=

# Wrapped CHZ (WCHZ) token address
# Required for: --all, --swap
WCHZ_ADDRESS=

# ==============================================================================
# OPTIONAL — Platform Configuration
# ==============================================================================

# Platform fee in basis points (default: 500 = 5%)
# Used by ChilizSwapRouter and StreamWalletFactory.
# Examples: 100 = 1%, 200 = 2%, 500 = 5%, 1000 = 10%
PLATFORM_FEE_BPS=500

# ── LiquidityPool tunables (all optional, sensible defaults applied) ─────────
# Stake skim taken at bet placement and routed to accruedTreasury.
# Default 200 bps = 2%. Max settable 1000 bps = 10%.
PROTOCOL_FEE_BPS=200
# Per-market liability cap as % of NAV. Default 500 bps = 5%.
MAX_MARKET_LIAB_BPS=500
# Per-match liability cap as % of NAV. Default 2000 bps = 20%.
MAX_MATCH_LIAB_BPS=2000
# LP withdrawal cooldown after deposit, seconds. Default 3600 = 1h.
DEPOSIT_COOLDOWN_SECS=3600
# Pool-wide per-bet cap in USDC atomic units (6 decimals).
# Default 10_000_000_000 = 10,000 USDC. Set to 0 to disable the cap.
MAX_BET_AMOUNT=10000000000

# ==============================================================================
# OPTIONAL — Verification
# ==============================================================================

# Block explorer API key (for --verify flag)
ETHERSCAN_API_KEY=

# ==============================================================================
# DEPLOYED ADDRESSES (filled after deployment)
# ==============================================================================
# Save these after running deploy.sh or forge script.

BETTING_FACTORY=
STREAM_FACTORY=
SWAP_ROUTER=
PAYOUT_ESCROW=

# ==============================================================================
# SECURITY BEST PRACTICES
# ==============================================================================
#
# DEPLOYMENT KEY vs MULTISIG:
# ✅ DO:
#    - Use a dedicated HOT wallet for PRIVATE_KEY (deployment only)
#    - Fund it with minimal gas (~0.5-1 CHZ for deployment)
#    - Deploy contracts with this key
#    - Ownership automatically transfers to SAFE_ADDRESS
#    - Delete/rotate the deployment key after successful deployment
#
# ❌ DON'T:
#    - Never deploy directly from a multisig (won't work)
#    - Never use your main wallet's private key
#    - Never leave the deployer as owner on mainnet
#    - Never commit .env file to git
#
# RECOMMENDED FLOW:
#    1. Generate fresh deployment keypair
#    2. Fund with 1 CHZ for gas
#    3. Run: ./deploy.sh --network chilizTestnet --all
#    4. Verify contracts on explorer
#    5. Confirm ownership is SAFE_ADDRESS
#    6. Rotate/delete deployment key
#
# POST-DEPLOYMENT (from Gnosis Safe UI):
#    For each BettingMatch proxy:
#      a) setUSDCToken(USDC_ADDRESS)
#      b) grantRole(SWAP_ROUTER_ROLE, SWAP_ROUTER)
#      c) setPayoutEscrow(PAYOUT_ESCROW)
#    On PayoutEscrow:
#      a) authorizeMatch(MATCH_PROXY_ADDRESS)
#      b) USDC.approve(PAYOUT_ESCROW, amount)
#      c) PayoutEscrow.fund(amount)
